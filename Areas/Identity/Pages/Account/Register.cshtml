@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container py-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="row g-0">

                    <div class="col-md-7 p-4 p-md-5 bg-white">
                        <div class="mb-4">
                            <h2 class="fw-bold text-dark">Create an account</h2>
                            <p class="text-muted">Join Digital Finance and take control of your future.</p>
                        </div>

                        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold" role="alert"></div>

                            <div class="form-floating mb-3">
                                <input asp-for="Input.Email" class="form-control bg-light border-0" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                                <label asp-for="Input.Email" class="text-muted"><i class="bi bi-envelope me-2"></i>Email address</label>
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Input.Password" class="form-control bg-light border-0" autocomplete="new-password" aria-required="true" placeholder="password" />
                                <label asp-for="Input.Password" class="text-muted"><i class="bi bi-lock me-2"></i>Password</label>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-4">
                                <input asp-for="Input.ConfirmPassword" class="form-control bg-light border-0" autocomplete="new-password" aria-required="true" placeholder="password" />
                                <label asp-for="Input.ConfirmPassword" class="text-muted"><i class="bi bi-shield-lock me-2"></i>Confirm Password</label>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary fw-bold shadow-sm mb-3">
                                Create Account
                            </button>

                            <div class="text-center mt-3">
                                <span class="text-muted small">Already have an account?</span>
                                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold small ms-1">Log in here</a>
                            </div>
                        </form>
                    </div>

                    <div class="col-md-5 bg-primary text-white p-4 p-md-5 d-flex flex-column justify-content-between">
                        <div>
                            <h3 class="fw-bold mb-3"><i class="bi bi-wallet2 me-2"></i>Digital Finance</h3>
                            <p class="text-white-50 mb-4">
                                Experience bank-grade security, lightning-fast loan approvals, and a modern digital dashboard built for your convenience.
                            </p>

                            <ul class="list-unstyled mb-0">
                                <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2 border border-white rounded-circle bg-white"></i> Secure Transactions</li>
                                <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2 border border-white rounded-circle bg-white"></i> 24/7 Account Access</li>
                                <li><i class="bi bi-check-circle-fill text-success me-2 border border-white rounded-circle bg-white"></i> Instant Loan Processing</li>
                            </ul>
                        </div>

                        <div class="mt-5 pt-4 border-top border-light border-opacity-25">
                            <p class="small text-white-50 mb-3">Or register using a trusted provider:</p>

                            @{
                                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                                {
                                    <div class="alert alert-primary bg-opacity-25 border-0 text-white small p-3">
                                        <i class="bi bi-info-circle me-1"></i> External logins are currently disabled.
                                    </div>
                                }
                                else
                                {
                                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                                        <div class="d-grid gap-2">
                                            @foreach (var provider in Model.ExternalLogins!)
                                            {
                                                <button type="submit" class="btn btn-outline-light" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                                    <i class="bi bi-google me-2"></i> Continue with @provider.DisplayName
                                                </button>
                                            }
                                        </div>
                                    </form>
                                }
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}