@model Loan_Processing_Inzamam.ViewModels.TransactionViewModel

@{
    ViewData["Title"] = "Deposit or Withdraw Funds";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0 fw-bold">Make a Transaction</h4>
                </div>
                <div class="card-body p-4">

                    <form asp-controller="Transaction" asp-action="MakeTransaction" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-4">
                            <label asp-for="AccountId" class="control-label fw-bold"></label>
                            <select asp-for="AccountId" class="form-select" asp-items="ViewBag.Accounts">
                                <option value="">-- Select Account --</option>
                            </select>
                            <span asp-validation-for="AccountId" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="TransactionType" class="control-label fw-bold"></label>
                            <select asp-for="TransactionType" class="form-select">
                                <option value="">-- Select Transaction --</option>
                                <option value="Deposit">Deposit Funds</option>
                                <option value="Withdraw">Withdraw Funds</option>
                            </select>
                            <span asp-validation-for="TransactionType" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Amount" class="control-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light fw-bold">৳</span>
                                <input asp-for="Amount" class="form-control form-control-lg" type="number" step="0.01" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger d-block mt-1"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg fw-bold">Confirm Transaction</button>
                            <a asp-controller="Client" asp-action="Dashboard" class="btn btn-light border">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}