@model Loan_Processing_Inzamam.ViewModels.EmployeeCreateViewModel

@{
    Layout = null;
}

<div id="formContainer" class="p-2 p-md-3">
    <form id="employeeForm" action="@Url.Action("Create", "Employees")" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="row g-4">
            <div class="col-md-6">
                <h5 class="text-primary border-bottom pb-2 mb-3">Account & Job Info</h5>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="control-label fw-bold small"></label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="control-label fw-bold small"></label>
                        <input asp-for="Password" class="form-control" type="password" />
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold small"></label>
                    <input asp-for="Name" class="form-control" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DesignationId" class="control-label fw-bold small"></label>
                        <select asp-for="DesignationId" class="form-select" asp-items="ViewBag.Designations">
                            <option value="">-- Select --</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="BranchId" class="control-label fw-bold small"></label>
                        <select asp-for="BranchId" class="form-select" asp-items="ViewBag.Branches">
                            <option value="">-- Select --</option>
                        </select>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ServiceCategory" class="control-label fw-bold small"></label>
                    <input asp-for="ServiceCategory" class="form-control" placeholder="e.g. Credit Services" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="PhotoUpload" class="control-label fw-bold small"></label>
                    <input asp-for="PhotoUpload" type="file" class="form-control" accept="image/*" id="PhotoInput" />

                    <div class="mt-3 text-center" id="previewContainer" style="display: none;">
                        <img id="imagePreview" src="" alt="Profile Preview" class="img-thumbnail rounded-circle shadow-sm" style="width: 120px; height: 120px; object-fit: cover;" />
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <h5 class="text-primary border-bottom pb-2 mb-3">Personal Info</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="control-label fw-bold small"></label>
                        <input asp-for="Phone" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="DateOfBirth" class="control-label fw-bold small"></label>
                        <input asp-for="DateOfBirth" class="form-control" type="date" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="NIDNumber" class="control-label fw-bold small"></label>
                        <input asp-for="NIDNumber" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="MaritalStatus" class="control-label fw-bold small"></label>
                        <select asp-for="MaritalStatus" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="Single">Single</option>
                            <option value="Married">Married</option>
                        </select>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="PresentAddress" class="control-label fw-bold small"></label>
                    <textarea asp-for="PresentAddress" class="form-control" rows="2"></textarea>
                </div>

                <div class="form-check mb-2">
                    <input asp-for="IsSameAddress" class="form-check-input" id="chkSameAddress" />
                    <label class="form-check-label small fw-semibold" for="chkSameAddress">Permanent Address is same</label>
                </div>

                <div class="form-group mb-3" id="divPermAddress">
                    <label asp-for="PermanentAddress" class="control-label fw-bold small"></label>
                    <textarea asp-for="PermanentAddress" class="form-control" rows="2"></textarea>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2">
                    <h5 class="text-primary mb-0">Educational Qualifications</h5>
                    <button type="button" id="btnAddDegree" class="btn btn-sm btn-outline-success fw-bold">+ Add Degree</button>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered table-sm mt-2" id="eduTable">
                        <thead class="table-light">
                            <tr>
                                <th>Degree Name</th>
                                <th>Institution Name</th>
                                <th style="width: 120px;">Passing Year</th>
                                <th style="width: 100px;">Score</th>
                                <th style="width: 90px;">Out Of</th>
                                <th style="width: 80px;" class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="eduBody">
                            <tr class="border-bottom border-light">
                                <td><input name="Qualifications[0].DegreeName" class="form-control form-control-sm bg-light border-0" required /></td>
                                <td><input name="Qualifications[0].InstitutionName" class="form-control form-control-sm bg-light border-0" required /></td>
                                <td><input name="Qualifications[0].PassingYear" type="number" class="form-control form-control-sm bg-light border-0" required /></td>
                                <td><input name="Qualifications[0].GradingScore" type="number" step="0.01" class="form-control form-control-sm bg-light border-0" required /></td>
                                <td>
                                    <select name="Qualifications[0].OutOf" class="form-select form-select-sm bg-light border-0">
                                        <option value="4.0">4.0</option>
                                        <option value="5.0">5.0</option>
                                    </select>
                                </td>
                                <td class="text-center"><button type="button" class="btn btn-sm btn-danger remove-row" disabled><i class="bi bi-trash"></i></button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="errorContainer" class="alert alert-danger d-none mt-3" role="alert">
            <ul id="errorList" class="mb-0"></ul>
        </div>

        <div class="mt-4 text-end">
            <button type="button" class="btn btn-secondary btn-lg px-4 shadow-sm me-2" data-bs-dismiss="modal">Cancel</button>
            <button type="button" id="btnSubmitAjax" class="btn btn-primary btn-lg px-5 shadow-sm">
                <span id="btnText">Submit & Save</span>
                <span id="btnSpinner" class="spinner-border spinner-border-sm d-none ms-2" role="status" aria-hidden="true"></span>
            </button>
        </div>
    </form>
</div>