@model Loan_Processing_Inzamam.ViewModels.EmployeeEditViewModel

@{
    Layout = null;
}

<div id="formContainer" class="p-2 p-md-3">
    <form id="employeeEditForm" action="@Url.Action("Edit", "Employees")" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="EmployeeId" />
        <input type="hidden" asp-for="ApplicationUserId" />
        <input type="hidden" asp-for="ExistingPhotoPath" />

        <div class="row g-4">
            <div class="col-lg-7">
                <h5 class="text-primary border-bottom pb-2 mb-3">General Information</h5>

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold small"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-person"></i></span>
                        <input asp-for="Name" class="form-control" placeholder="Employee Full Name" />
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Phone" class="control-label fw-bold small"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-telephone"></i></span>
                        <input asp-for="Phone" class="form-control" placeholder="Contact Number" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="DesignationId" class="control-label fw-bold small">Designation</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-briefcase"></i></span>
                            <select asp-for="DesignationId" class="form-select" asp-items="ViewBag.Designations">
                                <option value="">-- Select --</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="BranchId" class="control-label fw-bold small">Branch</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-building"></i></span>
                            <select asp-for="BranchId" class="form-select" asp-items="ViewBag.Branches">
                                <option value="">-- Head Office --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ServiceCategory" class="control-label fw-bold small">Service Category</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-tags"></i></span>
                        <input asp-for="ServiceCategory" class="form-control" placeholder="e.g. Permanent, Contractual" />
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <h5 class="text-primary border-bottom pb-2 mb-3">Profile Photo</h5>

                <div class="form-group mb-4 text-center bg-light p-4 rounded-3 border border-light shadow-sm">
                    @{
                        var hasExistingPhoto = !string.IsNullOrEmpty(Model.ExistingPhotoPath);
                        var displayImg = hasExistingPhoto ? "inline-block" : "none";
                        var displayPlaceholder = hasExistingPhoto ? "d-none" : "d-flex";
                        var imgSrc = hasExistingPhoto ? Url.Content("~/images/employees/" + Model.ExistingPhotoPath) : "";
                    }

                    <div class="mb-3 position-relative d-inline-block">
                        <img id="imagePreview" src="@imgSrc" class="rounded-circle img-thumbnail shadow-sm bg-white" style="width: 120px; height: 120px; object-fit: cover; display: @displayImg;" alt="Employee Photo" />

                        <div id="previewPlaceholder" class="@displayPlaceholder align-items-center justify-content-center rounded-circle bg-secondary bg-opacity-10 text-muted shadow-sm mx-auto" style="width: 120px; height: 120px; border: 2px dashed #dee2e6;">
                            <div class="text-center">
                                <i class="bi bi-person-bounding-box fs-1 d-block mb-1"></i>
                                <small>No photo</small>
                            </div>
                        </div>
                    </div>

                    <label class="d-block text-muted small mb-2">Upload a new photo to replace.</label>
                    <input asp-for="PhotoUpload" type="file" class="form-control form-control-sm" accept="image/*" id="PhotoInput" />
                </div>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2">
                    <h5 class="text-primary mb-0">Educational Qualifications</h5>
                    <button type="button" id="btnAddDegree" class="btn btn-sm btn-outline-success fw-bold">+ Add Degree</button>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered table-sm mt-2" id="eduTable">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-2">Degree Name</th>
                                <th>Institution Name</th>
                                <th style="width: 120px;">Passing Year</th>
                                <th style="width: 100px;">Score</th>
                                <th style="width: 90px;">Out Of</th>
                                <th style="width: 60px;" class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="eduBody">
                            @if (Model.Qualifications != null && Model.Qualifications.Any())
                            {
                                for (int i = 0; i < Model.Qualifications.Count; i++)
                                {
                                    <tr class="border-bottom border-light">
                                        <td class="ps-2"><input asp-for="Qualifications[i].DegreeName" class="form-control form-control-sm bg-light border-0" required /></td>
                                        <td><input asp-for="Qualifications[i].InstitutionName" class="form-control form-control-sm bg-light border-0" required /></td>
                                        <td><input asp-for="Qualifications[i].PassingYear" type="number" class="form-control form-control-sm bg-light border-0" required /></td>
                                        <td><input asp-for="Qualifications[i].GradingScore" type="number" step="0.01" class="form-control form-control-sm bg-light border-0" required /></td>
                                        <td>
                                            <select asp-for="Qualifications[i].OutOf" class="form-select form-select-sm bg-light border-0">
                                                <option value="4.0">4.0</option>
                                                <option value="5.0">5.0</option>
                                            </select>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-outline-danger border-0 remove-row" title="Remove row">
                                                <i class="bi bi-trash" style="pointer-events: none;"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="errorContainer" class="alert alert-danger d-none mt-3" role="alert">
            <ul id="errorList" class="mb-0"></ul>
        </div>

        <div class="mt-4 text-end">
            <button type="button" class="btn btn-secondary btn-lg px-4 shadow-sm me-2" data-bs-dismiss="modal">Cancel</button>
            <button type="button" id="btnSubmitAjax" class="btn btn-primary btn-lg px-5 shadow-sm">
                <span id="btnText">Save Changes</span>
                <span id="btnSpinner" class="spinner-border spinner-border-sm d-none ms-2" role="status" aria-hidden="true"></span>
            </button>
        </div>
    </form>
</div>