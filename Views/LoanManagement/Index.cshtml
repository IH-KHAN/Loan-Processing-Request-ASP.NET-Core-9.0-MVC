@model IEnumerable<Loan_Processing_Inzamam.Models.LoanRequest>

@{
    ViewData["Title"] = "Loan Management";
}

<div class="container py-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">Loan Applications Queue</h2>
            <p class="text-muted small mb-0">Review and process incoming loan requests from clients.</p>
        </div>
        <div class="badge bg-primary bg-opacity-10 text-primary p-2 px-3 rounded-pill border border-primary border-opacity-25">
            <i class="bi bi-clock-history me-1"></i> @Model.Count() Total Requests
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive bg-white">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Submission Date</th>
                        <th>Client Details</th>
                        <th>Loan Information</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted">No pending loan requests found.</td></tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr class="border-bottom border-light">
                                <td class="ps-4">
                                    <div class="text-dark fw-medium">@item.RequestDate.ToString("MMM dd, yyyy")</div>
                                    <small class="text-muted">@item.RequestDate.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.Client?.Name</div>
                                    <small class="text-muted">ID: #CL-@item.ClientId</small>
                                </td>
                                <td>
                                    <div class="text-dark fw-medium">@item.LoanType?.TypeName</div>
                                    <small class="text-muted">@item.LoanTermMonths Months Term</small>
                                </td>
                                <td>
                                    <span class="text-primary fw-bold">৳ @item.DesiredLoanAmount.ToString("N2")</span>
                                </td>
                                <td>
                                    @{
                                        var badgeClass = item.Status switch
                                        {
                                            "Pending" => "bg-warning text-dark border-warning",
                                            "Approved" => "bg-success text-success border-success",
                                            "Rejected" => "bg-danger text-danger border-danger",
                                            _ => "bg-secondary text-secondary border-secondary"
                                        };
                                    }
                                    <span class="badge rounded-pill @badgeClass bg-opacity-10 border border-opacity-25 px-3 py-2">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@item.LoanRequestId" class="btn btn-sm btn-outline-primary fw-bold px-3 rounded-pill">
                                        Review <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>