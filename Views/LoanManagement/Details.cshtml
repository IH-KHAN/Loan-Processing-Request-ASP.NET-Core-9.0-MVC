@model Loan_Processing_Inzamam.ViewModels.LoanProcessViewModel
@{
    ViewData["Title"] = "Credit Review";
    var loan = ViewBag.LoanDetails as Loan_Processing_Inzamam.Models.LoanRequest;
}

<div class="container py-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Loan Queue</a></li>
                    <li class="breadcrumb-item active">Application #@loan.LoanRequestId</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-dark">Review Loan Application</h2>
        </div>
        <div class="text-end">
            <span class="text-muted d-block small">Submitted On</span>
            <span class="fw-bold"><i class="bi bi-calendar3 me-1"></i> @loan.RequestDate.ToString("MMMM dd, yyyy")</span>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">

            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white py-3 border-bottom border-light d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-person-check me-2"></i>Borrower & Document Verification</h5>
                    <span class="badge bg-light text-dark border">Client ID: #@loan.ClientId</span>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="small text-muted d-block">Full Name</label>
                            <span class="fw-bold fs-5 text-dark">@loan.Client?.Name</span>
                        </div>
                        <div class="col-md-6">
                            <label class="small text-muted d-block">Verified Annual Income</label>
                            <span class="fw-bold text-success fs-5">৳ @loan.AnnualIncome.ToString("N2")</span>
                        </div>
                        <div class="col-md-6">
                            <label class="small text-muted d-block">Requested Loan Amount</label>
                            <span class="fw-bold text-primary fs-5">৳ @loan.DesiredLoanAmount.ToString("N2")</span>
                        </div>
                        <div class="col-md-3">
                            <label class="small text-muted d-block">Loan Term</label>
                            <span class="fw-bold fs-5 text-dark">@loan.LoanTermMonths Months</span>
                        </div>
                        <div class="col-md-3">
                            <label class="small text-muted d-block">Loan Type</label>
                            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">@loan.LoanType?.TypeName</span>
                        </div>

                        <div class="col-12">
                            <div class="p-3 rounded-3 border bg-light">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <label class="small text-muted d-block fw-bold text-uppercase" style="letter-spacing: 0.5px;">Taxpayer Identification Number (TIN)</label>
                                        @if (!string.IsNullOrEmpty(loan.TINFilePath))
                                        {
                                            <div class="mt-1">
                                                <i class="bi bi-file-earmark-check text-success me-1"></i>
                                                <span class="text-dark small">Document uploaded: <strong>@loan.TINFilePath</strong></span>
                                            </div>
                                        }
                                    </div>
                                    <div>
                                        @if (!string.IsNullOrEmpty(loan.TINFilePath))
                                        {
                                            <a href="~/documents/tin_certificates/@loan.TINFilePath" target="_blank" class="btn btn-sm btn-dark px-3 shadow-sm">
                                                <i class="bi bi-eye me-1"></i> View TIN Certificate
                                            </a>
                                            <a href="~/documents/tin_certificates/@loan.TINFilePath" download class="btn btn-sm btn-outline-secondary px-2 shadow-sm">
                                                <i class="bi bi-download"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <div class="text-danger small fw-bold">
                                                <i class="bi bi-exclamation-triangle-fill me-1"></i> DOCUMENT MISSING
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="small text-muted d-block">Stated Purpose of Loan</label>
                            <p class="mt-1 mb-0 text-dark" style="font-size: 0.95rem; line-height: 1.6;">
                                @loan.LoanPurpose
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white py-3 border-bottom border-light">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-shield-check me-2 text-info"></i>Guarantor Verification</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light small">
                                <tr>
                                    <th class="ps-4">Full Name</th>
                                    <th>Relation</th>
                                    <th>Contact Info</th>
                                    <th class="pe-4">Current Address</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (loan.Guarantors != null && loan.Guarantors.Any())
                                {
                                    foreach (var g in loan.Guarantors)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold">@g.Name</div>
                                            </td>
                                            <td><span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 fw-normal">@g.Relationship</span></td>
                                            <td>
                                                <div class="small"><i class="bi bi-telephone me-1 text-muted"></i> @g.Phone</div>
                                            </td>
                                            <td class="pe-4">
                                                <div class="small text-muted" style="max-width: 250px;">@g.ContactAddress</div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            <i class="bi bi-info-circle d-block fs-2 mb-2"></i>
                                            No guarantors provided for this application.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow border-0 rounded-4 sticky-top" style="top: 100px; z-index: 10;">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="fw-bold mb-0 text-center">Review Decision</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4 text-center">
                        <label class="small text-muted d-block mb-1 text-uppercase fw-bold" style="letter-spacing: 1px;">Current Status</label>
                        @{
                            var badgeClass = loan.Status switch
                            {
                                "Pending" => "bg-warning text-dark",
                                "Approved" => "bg-success text-white",
                                "Rejected" => "bg-danger text-white",
                                _ => "bg-secondary text-white"
                            };
                        }
                        <span class="badge rounded-pill @badgeClass px-4 py-2 fs-6">@loan.Status</span>
                    </div>

                    @if (loan.Status != "Pending")
                    {
                        <div class="bg-light p-3 rounded-3 border mb-4 shadow-sm">
                            <label class="small text-muted d-block border-bottom mb-2 pb-1">Previous Review Details</label>
                            <div class="small mb-1"><strong>Reviewer:</strong> @(loan.ApprovedByEmployee?.Name ?? "Administrator")</div>
                            <div class="small mb-1"><strong>Action Date:</strong> @loan.ActionDate?.ToString("MMM dd, yyyy")</div>
                            <div class="small"><strong>Remarks:</strong> @loan.AdminRemarks</div>
                        </div>
                    }

                    <form asp-action="ProcessLoan" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                        <input type="hidden" asp-for="LoanRequestId" />

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label fw-bold small">Final Decision</label>
                            <select asp-for="Status" class="form-select border-2">
                                <option value="">-- Select Decision --</option>
                                <option value="Approved">Approve Application</option>
                                <option value="Rejected">Reject Application</option>
                                <option value="Hold">Put on Hold</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="AdminRemarks" class="form-label fw-bold small">Decision Justification</label>
                            <textarea asp-for="AdminRemarks" class="form-control" rows="5" placeholder="Provide professional remarks for the client and bank records..."></textarea>
                            <span asp-validation-for="AdminRemarks" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">
                            Submit Review
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>