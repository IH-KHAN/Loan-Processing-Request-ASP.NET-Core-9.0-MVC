@model Loan_Processing_Inzamam.Models.Client

@{
    ViewData["Title"] = "My Dashboard";
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-primary text-white shadow-sm">
                <div class="card-body d-flex align-items-center">
                    @if (!string.IsNullOrEmpty(Model.PhotoPath))
                    {
                        <img src="~/images/clients/@Model.PhotoPath" alt="Profile" class="rounded-circle me-3 border border-2 border-white" style="width: 60px; height: 60px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-light text-primary d-flex justify-content-center align-items-center me-3 fw-bold fs-4" style="width: 60px; height: 60px;">
                            @Model.Name.Substring(0, 1).ToUpper()
                        </div>
                    }
                    <div>
                        <h3 class="mb-0">Welcome back, @Model.Name!</h3>
                        <p class="mb-0 text-white-50">SecureBank Client Dashboard</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light fw-bold">Quick Actions</div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        <a asp-controller="Loan" asp-action="RequestLoan" class="list-group-item list-group-item-action text-primary fw-semibold">
                            + Apply for a New Loan
                        </a>
                        <a asp-controller="BankAccount" asp-action="Create" class="list-group-item list-group-item-action">Open Bank Account</a>
                        <a asp-controller="Client" asp-action="EditProfile" class="list-group-item list-group-item-action">Update Profile Details</a>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light fw-bold">My Profile</div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><strong>Phone:</strong> <span class="text-muted">@Model.Phone</span></li>
                        <li class="mb-2"><strong>NID:</strong> <span class="text-muted">@Model.NIDNumber</span></li>
                        <li class="mb-2">
                            <strong>Status:</strong>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </li>
                        <li><strong>Member Since:</strong> <span class="text-muted">@Model.CreatedAt.ToString("MMM yyyy")</span></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light d-flex justify-content-between align-items-center fw-bold">
                    <span>My Loan Requests</span>
                    <span class="badge bg-secondary">@(Model.LoanRequests?.Count ?? 0)</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.LoanRequests == null || !Model.LoanRequests.Any())
                    {
                        <div class="p-4 text-center text-muted">
                            You currently have no active loan requests.
                        </div>
                    }
                    else
                    {
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Loan Type</th>
                                    <th>Amount</th>
                                    <th>Duration</th>
                                    <th>Paid So Far</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loan in Model.LoanRequests.OrderByDescending(l => l.RequestDate))
                                {
                                    <tr>
                                        <td class="fw-semibold text-dark">@loan.LoanType?.TypeName</td>
                                        <td class="fw-semibold">৳ @loan.DesiredLoanAmount.ToString("N2")</td>
                                        <td>@loan.LoanTermMonths Months</td>
                                        <td class="text-success fw-semibold">৳ @(loan.LoanInstallments?.Sum(li => li.AmountPaid).ToString("N2") ?? "0.00")</td>
                                        <td>
                                            @if (loan.Status == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark">Pending</span>
                                            }
                                            else if (loan.Status == "Approved")
                                            {
                                                <span class="badge bg-success">Approved</span>
                                            }
                                            else if (loan.Status == "Rejected")
                                            {
                                                <span class="badge bg-danger">Rejected</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@loan.Status</span>
                                            }
                                        </td>
                                        <td>
                                            @if (loan.Status == "Approved")
                                            {
                                                var totalPaidAmount = loan.LoanInstallments?.Sum(li => li.AmountPaid) ?? 0m;
                                                if (totalPaidAmount < loan.DesiredLoanAmount)
                                                {
                                                    <a asp-controller="Loan" asp-action="PayInstallment" asp-route-loanRequestId="@loan.LoanRequestId" class="btn btn-sm btn-outline-success">
                                                        <i class="bi bi-wallet2 me-1"></i>Pay Installment
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle"><i class="bi bi-check-circle-fill me-1"></i> Repaid</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted small">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center fw-bold">
                    <span>My Bank Accounts</span>
                    <span class="badge bg-secondary">@(Model.BankAccounts?.Count ?? 0)</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.BankAccounts == null || !Model.BankAccounts.Any())
                    {
                        <div class="p-4 text-center text-muted">
                            You do not have any linked bank accounts yet.
                        </div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var account in Model.BankAccounts)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                                    <div>
                                        <div class="fw-bold">Account #@account.AccountNumber</div>
                                        <small class="text-muted">Opened: @account.CreatedAt.ToString("MMM dd, yyyy")</small>
                                    </div>
                                    <div class="text-end">
                                        <div class="fs-5 fw-semibold text-success">৳ @account.Balance.ToString("N2")</div>
                                        <a asp-controller="Transaction" asp-action="MakeTransaction" class="btn btn-sm btn-outline-primary mt-1">Deposit / Withdraw</a>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>